# ViaStat — environment template (copy values into local .env / .env.local; never commit secrets)

# Backend
VIASTAT_DATA_DIR=./data
VIASTAT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VIASTAT_CORS_ORIGIN_REGEX=
VIASTAT_PORT=8000
VIASTAT_SEED=42

# Frontend (empty = same-origin in production / Vercel rewrites)
NEXT_PUBLIC_API_URL=

# Optional local demo proxy (scripts/demo-proxy.js)
# PROXY_PORT=3080
# FRONTEND_ORIGIN=http://127.0.0.1:3010
# BACKEND_ORIGIN=http://127.0.0.1:8123
